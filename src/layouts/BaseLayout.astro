---
import "../styles/global.css";
import logoImage from "../assets/logo.svg";

interface Props {
  title: string;
  description?: string;
  katex?: boolean;
}

const {
  title,
  description = "Shun Suzuki's homepage",
  katex = false,
} = Astro.props;
---

<!doctype html>
<html lang="ja" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    {
      katex && (
        <link
          rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/katex@0.16.42/dist/katex.min.css"
          integrity="sha384-DVShYR21zvUU4zL2VjLlIbYSeiS43grntDO/Sm1DwmGGXKxGmvBlXWZ9lnyKhota"
          crossorigin="anonymous"
        />
      )
    }
  </head>
  <body
    class="bg-[#0d1117] text-[#c9d1d9] min-h-screen font-sans antialiased selection:bg-[#264f78] selection:text-white flex flex-col"
  >
    <header
      class="border-b border-[#30363d] sticky top-0 bg-[#0d1117]/80 backdrop-blur-md z-10"
    >
      <div
        class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between"
      >
        <a
          href="/"
          class="flex items-center gap-2 hover:opacity-80 transition-opacity"
        >
          <img src={logoImage.src} alt="Logo" class="w-8 h-8 rounded" />
          <span class="font-semibold text-lg text-white tracking-wide"
            >Shun Suzuki</span
          >
        </a>
        <nav class="flex gap-6 text-sm font-medium text-[#8b949e]">
          <a href="/" class="hover:text-white transition-colors">Home</a>
          <a href="/posts" class="hover:text-white transition-colors">Posts</a>
        </nav>
      </div>
    </header>

    <main class="flex-grow max-w-5xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <slot />
    </main>

    <footer
      class="border-t border-[#30363d] py-8 text-center text-sm text-[#8b949e]"
    >
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <p>&copy; {new Date().getFullYear()} Shun Suzuki. Built with Astro.</p>
      </div>
    </footer>
  </body>
</html>
